# ──────────────────────────────────────────────
# WorkTF AI — Backend Environment Variables
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────

# Server port
PORT=

# MongoDB connection string
MONGODB_URI=

# Groq LLM API key
GROQ_API_KEY=

# VAPI voice AI credentials
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=

# Clerk authentication — secret (server-only) key
CLERK_SECRET_KEY=

# Allowed client origin for CORS
CLIENT_URL=
